---
import { Image } from "astro:assets";
import Base from "@layouts/Base.astro";
import { markdownify } from "@lib/utils/textConverter";
import { getEntry, render } from "astro:content";
import Disqus from "@components/Disqus";
import type { ImageMetadata } from "astro";

const entry = await getEntry("about", "index");
if (!entry) {
  return Astro.redirect("/404");
}
const { Content } = await render(entry);
const { title, meta_title, what_i_do } = entry.data;

const aboutImageGlob = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/about.webp",
  { eager: true },
);
const imageModule = aboutImageGlob["../assets/about.webp"];
---

<Base
  title={title}
  meta_title={meta_title}
>
  <section class="section">
    <div class="layout-container">
      <div class="row md:gx-4">
        <div class="sm:col-2 md:col-4">
          {
            imageModule && (
              <div class="mb-2">
                <Image
                  src={imageModule.default}
                  width={295}
                  height={395}
                  alt={title}
                  class="w-full px-20"
                />
              </div>
            )
          }
        </div>
        <div class="sm:col-7 md:col-8">
          <h1 set:html={markdownify(title)} class="h3 mb-8" />
          <div class="content">
            <Content />
          </div>
        </div>
      </div>
    </div>
  </section>

  {what_i_do && (
    <section class="section">
      <div class="layout-container">
        <h3 class="page-heading mb-10">{what_i_do.title}</h3>
        <div class="row gy-4 justify-center text-center">
          {
            what_i_do.items.map((item: any) => (
              <div class="md:col-6 lg:col-4 pb-6">
                <h4 class="font-weight-700 mb-3 text-primary">{item.title}</h4>
                <p>{item.description}</p>
              </div>
            ))
          }
        </div>
        <Disqus className="mt-20" client:load />
      </div>
    </section>
  )}
</Base>
