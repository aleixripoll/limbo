---
import Social from "@components/Social.astro";
import config from "@config/config.json";
import menu from "@config/menu.json";
import social from "@config/social.json";
---

<footer class="section mt-auto">
  <div class="mx-auto max-w-[1100px] px-4 text-center text-sm text-black/50 dark:text-white/50 border-t border-gray-200 pt-4 dark:border-gray-700">
    {/* footer menu */}
    {menu.footer.length > 0 && (
      <ul class="mb-4 space-x-4">
        {menu.footer.map((e) => (
          <li class="inline-block">
            <a
              href={`${import.meta.env.BASE_URL}${e["url"]}`}
              class="p-4 text-white/75 transition-all hover:text-primary"
            >
              {e["name"]}
            </a>
          </li>
        ))}
      </ul>
    )}
    {/* social icons */}
    <Social source={social} className="social-icons mb-4" />
    {/* copyright */}
    <p>
      © {new Date().getFullYear()}{" "}
      {config.site.logo_text || config.site.title}
    </p>
  </div>
</footer>
