---
import Logo from "@components/Logo.astro";
import menu from "@config/menu.json";
import { IoSearch } from "react-icons/io5/index.js";
import { BiUser, BiCategoryAlt, BiPurchaseTag } from "react-icons/bi/index.js";
import ThemeToggle from "./ThemeToggle.astro";

export interface ChildNavigationLink {
  name: string;
  url: string;
}

export interface NavigationLink {
  name: string;
  url: string;
  hasChildren?: boolean;
  children?: ChildNavigationLink[];
}

const { main }: { main: NavigationLink[] } = menu;

const menuIcons: Record<string, any> = {
  Autors: BiUser,
  Categories: BiCategoryAlt,
  Tags: BiPurchaseTag,
};

const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
let cur = Astro.url.pathname.replace(/\/$/, "") || "/";
if (basePath && cur.startsWith(basePath)) {
  cur = cur.slice(basePath.length) || "/";
}
if (!cur.startsWith("/")) cur = `/${cur}`;

function isActivePath(rel: string): boolean {
  const target = (`/${rel.replace(/^\//, "")}`).replace(/\/+/g, "/").replace(/\/$/, "") || "/";
  return cur === target || (target !== "/" && cur.startsWith(`${target}/`));
}
---

<header class="header relative z-40 bg-transparent pt-1">
  <nav
    class="navbar layout-container layout-container--header border-b border-gray-200 pb-1 dark:border-gray-700 dark:bg-transparent"
    aria-label="Principal"
  >
    <input id="nav-toggle" type="checkbox" class="hidden" autocomplete="off" />
    <label
      for="nav-toggle"
      class="nav-scrim"
      aria-hidden="true"
      tabindex="-1"
    ></label>

    <div class="order-0 relative z-12 flex min-w-0 shrink items-center">
      <Logo />
    </div>

    <label
      id="burger-button"
      for="nav-toggle"
      class="order-2 relative z-12 flex cursor-pointer items-center rounded-lg p-2.5 transition hover:bg-black/5 dark:hover:bg-white/10 md:order-1 md:hidden"
      aria-label="Obrir o tancar el menú"
      aria-controls="nav-menu"
      aria-expanded="false"
    >
      <div class="burger-icon">
        <span class="burger-bar bar-1"></span>
        <span class="burger-bar bar-2"></span>
        <span class="burger-bar bar-3"></span>
      </div>
    </label>

    <ul
      id="nav-menu"
      class="navbar-nav relative z-11 order-3 w-full gap-0.5 lowercase md:order-1 md:flex md:w-auto md:items-center md:gap-1"
    >
      {
        main.map((item) => (
          <>
            {item.hasChildren ? (
              <li class="nav-item nav-dropdown w-full md:w-auto">
                <details class="group nav-mobile-accordion md:hidden">
                  <summary class="nav-link flex cursor-pointer list-none items-center justify-center gap-1.5 rounded-lg py-3.5 [&::-webkit-details-marker]:hidden">
                    <span class="inline-flex items-center gap-1.5">
                      {item.name}
                      <svg
                        class="nav-chevron h-4 w-4 shrink-0 opacity-70 transition-transform duration-200 group-open:rotate-180 md:h-5 md:w-5"
                        viewBox="0 0 20 20"
                        aria-hidden="true"
                      >
                        <path
                          fill="currentColor"
                          d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"
                        />
                      </svg>
                    </span>
                  </summary>
                  <ul class="nav-dropdown-list nav-dropdown-list--mobile mt-1 space-y-0.5 border-l-2 border-primary/25 py-1 pl-4 dark:border-primary/40">
                    {item.children?.map((child) => (
                      <li class="nav-dropdown-item">
                        <a
                          href={`${import.meta.env.BASE_URL}${child.url}`}
                          class:list={[
                            "nav-dropdown-link rounded-md px-2 py-2",
                            isActivePath(child.url) && "nav-link--active",
                          ]}
                          aria-current={isActivePath(child.url) ? "page" : undefined}
                        >
                          {child.name}
                        </a>
                      </li>
                    ))}
                  </ul>
                </details>
                <div class="nav-desktop-dropdown group relative hidden md:block">
                  <span class="nav-link inline-flex cursor-pointer items-center gap-1">
                    {item.name}
                    <svg
                      class="nav-chevron h-5 w-5 shrink-0 opacity-70"
                      viewBox="0 0 20 20"
                      aria-hidden="true"
                    >
                      <path
                        fill="currentColor"
                        d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"
                      />
                    </svg>
                  </span>
                  <ul class="nav-dropdown-list nav-dropdown-list--desktop invisible absolute left-0 top-full z-20 mt-1 min-w-48 opacity-0 shadow-lg ring-1 ring-black/5 transition-[opacity,visibility] duration-150 ease-out group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100 dark:ring-white/10">
                    {item.children?.map((child) => (
                      <li class="nav-dropdown-item">
                        <a
                          href={`${import.meta.env.BASE_URL}${child.url}`}
                          class:list={[
                            "nav-dropdown-link",
                            isActivePath(child.url) && "nav-link--active",
                          ]}
                          aria-current={isActivePath(child.url) ? "page" : undefined}
                        >
                          {child.name}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </li>
            ) : (
              <li class="nav-item w-full md:w-auto">
                <a
                  href={`${import.meta.env.BASE_URL}${item.url}`}
                  class:list={[
                    "nav-link",
                    isActivePath(item.url) && "nav-link--active",
                  ]}
                  aria-current={isActivePath(item.url) ? "page" : undefined}
                >
                  {(() => {
                    const Icon = menuIcons[item.name];
                    return Icon ? (
                      <Icon className="h-5 w-5 shrink-0 text-current opacity-80" />
                    ) : null;
                  })()}
                  {item.name}
                </a>
              </li>
            )}
          </>
        ))
      }
    </ul>

    <div
      class="relative z-12 order-1 ml-auto flex shrink-0 items-center gap-1 sm:gap-2 md:order-2 md:ml-0"
    >
      <ThemeToggle />
      <a
        class="inline-flex cursor-pointer items-center justify-center rounded-lg p-2.5 text-xl text-dark transition hover:bg-black/5 hover:text-primary dark:text-light dark:hover:bg-white/10 md:p-2"
        href={`${import.meta.env.BASE_URL}search`}
        title="Cercar"
        aria-label="Cercar"
      >
        <IoSearch />
      </a>
    </div>
  </nav>
</header>

<script>
  function setupNav() {
    const input = document.getElementById("nav-toggle") as HTMLInputElement | null;
    const burger = document.getElementById("burger-button");
    const menu = document.getElementById("nav-menu");
    if (!input || !burger) return;

    const mq = window.matchMedia("(max-width: 767px)");

    const syncExpanded = () => {
      burger.setAttribute("aria-expanded", String(input.checked));
    };

    const closeIfMobile = () => {
      if (mq.matches) input.checked = false;
      syncExpanded();
    };

    const onKey = (e: KeyboardEvent) => {
      if (e.key === "Escape" && input.checked) {
        input.checked = false;
        syncExpanded();
        burger.focus();
      }
    };

    input.addEventListener("change", syncExpanded);
    document.addEventListener("keydown", onKey);

    const anchors = menu?.querySelectorAll("a") ?? [];
    anchors.forEach((a) => a.addEventListener("click", closeIfMobile));

    syncExpanded();

    return () => {
      input.removeEventListener("change", syncExpanded);
      document.removeEventListener("keydown", onKey);
      anchors.forEach((a) => a.removeEventListener("click", closeIfMobile));
    };
  }

  let teardown: (() => void) | undefined;
  const run = () => {
    teardown?.();
    teardown = setupNav();
  };
  run();
  document.addEventListener("astro:page-load", run);
</script>
