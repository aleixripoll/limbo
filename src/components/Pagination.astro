---
interface Props {
  /** e.g. `authors` for `/authors/page/2`; omit for home post listing */
  section?: string;
  currentPage: number;
  totalPages: number;
}

const { section, currentPage, totalPages } = Astro.props;

const baseUrl = import.meta.env.BASE_URL;

function hrefForPage(n: number): string {
  if (!section) {
    if (n <= 1) return baseUrl;
    return `${baseUrl}page/${n}`;
  }
  const sect = section.replace(/^\/+|\/+$/g, "");
  if (n <= 1) return `${baseUrl}${sect}`;
  return `${baseUrl}${sect}/page/${n}`;
}

const pageNumbers = Array.from({ length: totalPages }, (_, i) => i + 1);
const selectId = `pagination-select-${section ?? "posts"}-${currentPage}`;
---

{
  totalPages > 1 && (
    <nav class="pagination" aria-label="Paginació">
      {currentPage > 1 && (
        <a href={hrefForPage(currentPage - 1)} class="pagination-link pagination-prev">
          ← Anterior
        </a>
      )}

      <div class="pagination-jump">
        <label for={selectId} class="pagination-jump-label">
          Pàgina
        </label>
        <div class="pagination-select-wrap">
          <select id={selectId} class="pagination-select" data-pagination-select>
            {pageNumbers.map((n) => (
              <option value={hrefForPage(n)} selected={n === currentPage}>
                {n}
              </option>
            ))}
          </select>
        </div>
        <span class="pagination-jump-of">de {totalPages}</span>
      </div>

      {currentPage < totalPages && (
        <a href={hrefForPage(currentPage + 1)} class="pagination-link pagination-next">
          Següent →
        </a>
      )}
    </nav>
  )
}

<script is:inline>
  function initPaginationSelects() {
    document.querySelectorAll("[data-pagination-select]").forEach((el) => {
      if (el.dataset.paginationBound === "1") return;
      el.dataset.paginationBound = "1";
      el.addEventListener("change", (e) => {
        const t = e.target;
        const href = t && "value" in t ? t.value : "";
        if (href) window.location.href = href;
      });
    });
  }
  initPaginationSelects();
  document.addEventListener("astro:page-load", initPaginationSelects);
</script>
