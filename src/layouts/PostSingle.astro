---
import { Image } from "astro:assets";
import { render } from "astro:content";
//import Share from "@components/Share.astro";
// getSinglePage import removed (not used)
import dateFormat from "@lib/utils/dateFormat";
import { humanize, markdownify, slugify } from "@lib/utils/textConverter";
import CategoryGridIcon from "@components/CategoryGridIcon";
import { BiSolidChevronUpCircle } from "react-icons/bi/index.js";
import Disqus from "@components/Disqus";
//const allAuthors = await getSinglePage("authors");
const { post } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(post);
const { title, description, categories, image, image_attribution, date, tags } = post.data;

const lastModifiedIso = remarkPluginFrontmatter.lastModified as string | undefined;
---

<section class="section">
  <div class="layout-container max-w-[800px]">
    <article class="row justify-center -mx-4">
      {(image || image_attribution) && (
        <div class="col-12 md:col-10 mb-6 px-0 sm:px-2 w-auto">
          {
            image && (
              <Image
                src={image}
                widths={[320, 480, 640, 828, 1080]}
                quality={80}
                sizes={`(max-width: 640px) 100vw, 800px`}
                alt={title}
                class="sm:rounded-lg h-auto w-auto max-w-full object-scale-down block mx-auto"
                style={{
                  maxWidth: `min(100%, ${image.width}px)`,
                  maxHeight: `min(110vh, ${image.height}px)`,
                }}
              />
            )
          }
          {image_attribution && (
              <a target="_blank" href={post.data.image_attribution.url} class="attribution">
                Foto de {post.data.image_attribution.author} a {post.data.image_attribution.site}
              </a>
          )}
        </div>
      )}

      <div class="text-center md:col-10 px-4 md:px-0">
        <h1 set:html={markdownify(title)} class="h2 mt-0 mb-1 font-medium" />
        <p class="pt-1 pb-3 text-xl font-light leading-relaxed">{description}</p>
        <ul class="pt-1 flex flex-wrap items-center justify-center text-sm font-light">
          {/*<li class="mx-3">
            {
              allAuthors
                .filter((author: any) =>
                  authors
                    .map((author: string) => slugify(author))
                    .includes(slugify(author.data.title))
                )
                .map((author: any) => (
                  <a
                    href={`${import.meta.env.BASE_URL}authors/${slugify(author.id)}`}
                    class="flex items-center font-medium hover:text-primary"
                  >
                    {author.data.image && (
                      <Image
                        src={author.data.image}
                        alt={author.data.title}
                        height={50}
                        width={50}
                        class="mr-2 h-6 w-6 rounded-full"
                      />
                    )}
                    <BiUser className="mr-1 h-[18px] w-[18px]" />
                    <span>{author.data.title}</span>
                  </a>
                ))
            }
          </li>*/}
          <li class="pb-2 mx-2 flex flex-wrap items-center">
            {date ? dateFormat(date) : lastModifiedIso ? dateFormat(lastModifiedIso) : ""}
          </li>
          <li class="group pb-2 mx-2 flex flex-wrap items-center">
            <CategoryGridIcon className="mr-2 h-[18px] w-[18px] shrink-0 text-current transition-colors group-hover:text-primary" />
            <>
              <ul>
                {
                  categories.map((category: string, i: number) => (
                    <li class="inline-block">
                      <a
                        href={`${import.meta.env.BASE_URL}categories/${slugify(category)}`}
                        class="mr-1 transition-colors hover:text-primary"
                      >
                        {humanize(category)}{i !== post.data.categories.length - 1 && ","}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </>
          </li>
        </ul>
      </div>

      <div class="md:col-10">
        <div class="content mb-16 text-left">
          <Content />
        </div>
        <div class="flex flex-wrap items-center justify-between">
          <ul class="mb-4 mr-4 space-x-3">
            {
              tags.map((tag: string) => (
                <li class="inline-block mb-2">
                  <a
                    href={`${import.meta.env.BASE_URL}tags/${slugify(tag)}`}
                    class="block rounded-lg bg-theme-light dark:bg-theme-dark px-4 py-2 text-sm hover:text-primary"
                  >
                    # {humanize(tag, { capitalizeFirst: false })}
                  </a>
                </li>
              ))
            }
          </ul>
          {/* <Share
            className="social-share mb-4"
            title={title}
            description={description}
            slug={post.id}
          />*/}
        </div>
      </div>
    </article>
    <Disqus className="mt-20" client:load />
  </div>
</section>

<!-- similar posts -->
<!--{
  similarPosts.length > 0 && (
    <section class="section pt-0">
      <div class="layout-container">
        <h1 class="h3 mb-8 text-center uppercase font-light">Articles similars</h1>
        <SimilarPosts posts={similarPosts.slice(0, 4)} />
      </div>
    </section>
  )
}-->

<button
  id="scroll-to-top"
  class="fixed bottom-6 right-4 lg:right-20 xl:right-52 2xl:right-80 hidden whitespace-nowrap rounded-full opacity-80 bg-none hover:bg-primary hover:text-white"><BiSolidChevronUpCircle className="h-[50px] w-[50px]"/>
</button>

<script is:inline>
  // Initialize all functionality when DOM is ready
  function initializePage() {
    // Only add heading links if we're on a post page (check if scroll-to-top button exists)
    function addHeadingLinks() {
      // Only add heading links if we're on a post page
      if (!document.querySelector("#scroll-to-top")) {
        return;
      }
      
      // Only target headings within the main post content area
      let headings = Array.from(
        document.querySelectorAll(".content h1, .content h2, .content h3, .content h4")
      );
      for (let heading of headings) {
        if (!heading.id) {
          continue;
        }
        // Check if heading already has an anchor link to avoid duplicates
        if (heading.querySelector(".heading-link")) {
          continue;
        }
        
        heading.classList.add("group");
        let link = document.createElement("a");
        link.innerText = "#";
        link.className =
          "heading-link hidden group-hover:inline-block hover:text-primary ml-2 text-light no-underline";
        link.href = "#" + heading.id;
        link.ariaHidden = "true";
        heading.appendChild(link);
      }
    }
    
    // Scroll to top functionality
    function initScrollToTop() {
      const scrollButton = document.querySelector("#scroll-to-top");
      if (!scrollButton) return;
      
      // Show/hide button based on scroll position
      function scrollFunction() {
        if (
          document.body.scrollTop > 400 ||
          document.documentElement.scrollTop > 400
        ) {
          scrollButton.style.display = "block";
        } else {
          scrollButton.style.display = "none";
        }
      }
      
      // Add scroll event listener
      window.addEventListener("scroll", scrollFunction);
      
      // Add click event listener
      scrollButton.addEventListener("click", () => {
        window.scrollTo({
          top: 0,
          behavior: "smooth"
        });
      });
      
      // Initial check for scroll position
      scrollFunction();
    }
    
    // Initialize all functions
    addHeadingLinks();
    initScrollToTop();
  }
  
  // Wait for DOM to be ready
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initializePage);
  } else {
    // DOM is already ready
    initializePage();
  }
  
  // Also handle navigation events for SPA-like behavior
  document.addEventListener("astro:page-load", initializePage);
</script>
