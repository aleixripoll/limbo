---
import { Image } from "astro:assets";
//import { markdownify } from "@lib/utils/textConverter";
const { authors } = Astro.props;
---

<div class="row justify-center">
  {
    authors.map((author: any) => (
      <div class="group col-12 mb-8 sm:col-6 md:col-4">
        {author.data.image && (
          <div class="mb-4">
            <a
              href={`${import.meta.env.BASE_URL}authors/${author.id}`}
              class="block origin-center transition-transform duration-200 ease-out will-change-transform group-hover:scale-105"
            >
              <Image
                src={author.data.image}
                alt={author.data.title}
                widths={[320, 480, 640, 828, 1080]}
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 25vw"
                quality={80}
                class="mx-auto h-auto max-h-[300px] w-auto max-w-[min(100%,288px)] rounded-lg"
              />
            </a>
          </div>
        )}
        <h3 class="h4 mb-3 mt-8 text-2xl">
          <a
            href={`${import.meta.env.BASE_URL}authors/${author.id}`}
            class="block transition duration-200 group-hover:text-primary"
          >
            {author.data.title}
          </a>
        </h3>
        {author.data.description && (
          <p
            class="mb-3 text-lg font-light"
            set:text={author.data.description}
          />
        )}
        {/* <p
          class="mb-3"
          set:text={markdownify(author.body.slice(0, 68) + "...")}
        />*/}
        <a
          href={`${import.meta.env.BASE_URL}authors/${author.id}`}
          class="inline-flex items-center text-primary transition duration-200 group-hover:brightness-110"
        >
        </a>
      </div>
    ))
  }
</div>
